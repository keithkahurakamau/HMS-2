
# Copy to `.env` at the repo root before running `docker compose up`.
# Real secrets belong in a managed vault, not git.

# ── Postgres ────────────────────────────────────────────────────────────────
POSTGRES_USER=medifleet
POSTGRES_PASSWORD=medifleet
POSTGRES_DB=hms_master
POSTGRES_HOST_PORT=5432

# ── Redis ───────────────────────────────────────────────────────────────────
REDIS_HOST_PORT=6379

# ── Backend ─────────────────────────────────────────────────────────────────
BACKEND_HOST_PORT=8000
# SECRET_KEY: JWT signing secret. Must be >= 32 bytes of high-entropy random.
#   Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=
# ENCRYPTION_KEY: Fernet key for at-rest field encryption (app/utils/encryption.py).
#   MUST be generated with Fernet — boot fails on weak/low-entropy values.
#   Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=
CORS_ORIGINS=http://localhost:5173,http://localhost:8080
MIGRATE_ON_BOOT=1

# Superadmin bootstrap. Used by seed_superadmin.py on first boot only.
SEED_SUPERADMIN_EMAIL=superadmin@hms.co.ke
SEED_SUPERADMIN_PASSWORD=SuperAdmin@2026

# M-Pesa (sandbox is fine for local development)
MPESA_ENV=sandbox
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_PASSKEY=
MPESA_SHORTCODE=

# ── Email / SMTP ──────────────────────────────────────────────────────────────
# Provider-agnostic. Works with any SMTP relay (Gmail, Mailgun, Resend, AWS SES).
# Leave EMAIL_ENABLED=false in dev: emails are logged to the console instead of
# sent, and password-reset/invite tokens are surfaced inline for testing.
#
# PRODUCTION via Resend (https://resend.com) — recommended, no code change:
#   1. Add the medifleet.app domain in Resend → add the DKIM/SPF DNS records.
#   2. Create an API key.
#   3. Set the values below:
#        EMAIL_ENABLED=true
#        SMTP_HOST=smtp.resend.com
#        SMTP_PORT=587
#        SMTP_USER=resend
#        SMTP_PASSWORD=<your Resend API key>   # the API key IS the SMTP password
#        EMAIL_FROM=noreply@medifleet.app      # must be on the verified domain
#   Emails then arrive in any real inbox, readable on phone/laptop/any client.
EMAIL_ENABLED=false
SMTP_HOST=smtp.resend.com
SMTP_PORT=587
SMTP_USER=resend
SMTP_PASSWORD=            # Resend API key (re_...)
SMTP_USE_TLS=true          # STARTTLS (port 587). Set false + SMTP_USE_SSL=true for port 465.
SMTP_USE_SSL=false
EMAIL_FROM=noreply@medifleet.app
EMAIL_FROM_NAME=MediFleet
# Replies to system emails go here. Point at your support inbox so clients can
# just hit "reply". Receiving mail at this address needs MX + inbound configured
# on your mail provider for the domain (e.g. support@medifleet.app).
EMAIL_REPLY_TO=support@medifleet.app
# Base URL emailed links point at (no trailing slash). Defaults to first CORS origin.
FRONTEND_BASE_URL=http://localhost:5173
# Role-based sender identities. Ticket replies send "from" the right desk
# (Billing→finance, Bug/Feature→technical, else support). Empty falls back to EMAIL_FROM.
EMAIL_FROM_SUPPORT=support@medifleet.app
EMAIL_FROM_FINANCE=finance@medifleet.app
EMAIL_FROM_TECHNICAL=technical@medifleet.app
# Landing-page contact form delivers leads here. MUST be a real mailbox you
# read (e.g. your Gmail / Workspace), NOT an address whose MX points at Resend
# inbound. Falls back to EMAIL_REPLY_TO then EMAIL_FROM.
CONTACT_RECIPIENT_EMAIL=

# ── Inbound support email (EMAIL-003) ─────────────────────────────────────────
# Clients email support@/finance@/technical@<domain>; the provider POSTs the
# parsed message to /api/public/support/inbound, which files it as a ticket.
# Restricted to known contacts (sender must already have a ticket). Requires MX
# + an inbound webhook configured at the provider, pointed at the backend URL.
SUPPORT_INBOUND_ENABLED=false
SUPPORT_INBOUND_SIGNING_SECRET=          # HMAC secret from the provider's inbound webhook
SUPPORT_INBOUND_DOMAIN=medifleet.app     # used for support+ticket-<id>@ reply addresses

# ── Frontend ────────────────────────────────────────────────────────────────
FRONTEND_HOST_PORT=5173
